# Supabase project URL (from Supabase dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase publishable (anon) key — Supabase calls it "publishable key" in new projects
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # same value as above; used by @supabase/ssr client code

# Supabase service role key (server-side only, never expose to client)
# This is the canonical key name. SUPABASE_SERVICE_ROLE_KEY is NOT used.
SUPABASE_SECRET_KEY=

# Canonical public site URL — used by the login host fallback (auth/login/route.ts)
# and by the PagBank webhook URL builder (lib/pagbank/api.ts). Required in production.
NEXT_PUBLIC_SITE_URL=https://medhelpspace.com.br

# Postgres database password (from Supabase dashboard → Project Settings → Database)
# Used by scripts/run-sql.js to connect directly for migrations.
SUPABASE_DB_PASSWORD=

# Optional: override the full DB connection string (takes precedence over the above).
# Use this if you want the Transaction Pooler instead of the direct connection:
#   DATABASE_URL=postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres
# DATABASE_URL=

# Shared secret guarding the cron route handlers (api/cron/*). Vercel Cron sends it
# as `Authorization: Bearer <CRON_SECRET>`; the route rejects mismatches.
CRON_SECRET=

# Resend API key for transactional / lifecycle email (lib/email.ts). Email is
# silently skipped when unset.
RESEND_API_KEY=

# PagBank (payments) — server-side only, never expose to client.
# Production access token used for live charges/orders.
PAGBANK_ACCESS_TOKEN=
# Sandbox access token; used when PAGBANK_ENVIRONMENT=sandbox.
PAGBANK_ACCESS_TOKEN_SANDBOX=
# Which PagBank environment to hit: "production" (default) or "sandbox".
PAGBANK_ENVIRONMENT=production
# Token used to authenticate inbound PagBank webhooks (falls back to the access token).
PAGBANK_WEBHOOK_TOKEN=
# Base URL PagBank should call back; defaults to NEXT_PUBLIC_SITE_URL when unset.
PAGBANK_WEBHOOK_BASE_URL=
# Set to "true" to enforce webhook signature verification (reject unverified calls).
PAGBANK_WEBHOOK_ENFORCE=

# Bunny CDN storage (audio uploads from the admin panel). Server-side only.
# API/storage key — BUNNY_STORAGE_PASSWORD is preferred; BUNNY_API_KEY is the fallback.
BUNNY_API_KEY=
# Storage zone endpoint, e.g. https://storage.bunnycdn.com/<zone>/
BUNNY_STORAGE_ENDPOINT=
# Storage zone password (preferred over BUNNY_API_KEY).
BUNNY_STORAGE_PASSWORD=

# PagBank card-encryption public key. Exposed to the client (NEXT_PUBLIC_) to
# tokenize card data in the browser before it reaches our server.
NEXT_PUBLIC_PAGBANK_PUBLIC_KEY=

# eNotas (NFS-e / nota fiscal issuance) — server-side only, never expose to client.
# API key from the eNotas dashboard (your name → "configurações para nerds" →
# Copiar API Key, or https://app.enotas.com.br/apikey). Sent as HTTP Basic auth
# with the key as the username and an empty password.
ENOTAS_API_KEY=
# eNotas empresa GUID for MEDHELPSPACE LTDA. If unset, the client resolves it via
# GET /empresas on first use.
ENOTAS_EMPRESA_ID=
# Which eNotas ambiente to emit in: "homologacao" (no real notes) or "producao".
# Start in homologacao; flip to producao only after a validated live nota.
ENOTAS_ENVIRONMENT=homologacao
# Secret token used to verify inbound eNotas status webhooks (fail-closed when set).
ENOTAS_WEBHOOK_SECRET=
# Fiscal service constants (confirmed via the 2026-06-27 test note): item LC116
# 8.02, código de serviço municipal 0802, ISS 5%. Used to build the NFS-e servico block.
ENOTAS_SERVICO_ITEM_LC116=8.02
ENOTAS_SERVICO_CODIGO_MUNICIPIO=0802
ENOTAS_SERVICO_ALIQUOTA_ISS=5
ENOTAS_SERVICO_DESCRICAO=

# Dev-only: set to "true" to force mock-data mode (runs the UI offline on seeded
# mock data, bypassing Supabase). Has NO effect in production builds — never set
# this in a deployed environment.
NEXT_PUBLIC_USE_MOCK_DATA=
