# Large data files — do not commit
db.sql
*.gz
*.sql.gz

# Migration output — regenerable from db.sql + parser.py
parsed/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Node (root-level scripts)
node_modules/

# Claude Code local project settings
.claude/

# Editor / OS
.DS_Store
Thumbs.db
*.swp

# Secrets — never commit
.env
.env.local
.env*.local

# Next.js build output (also ignored in app/.gitignore)
app/.next/
app/out/

# Vercel
.vercel

# Raw image scratch folder — large, unoptimized stock downloads.
# Curated + optimized images belong in app/public/images/ instead.
images/

# Local lint output dump — regenerable via `npm run lint`
app/lint_results.txt

# /mobile-check skill screenshots — regenerable, not part of the codebase
.mobile-check-*.png

# Scratch / one-off debug scripts (convention: filename prefix with `_`)
scripts/_*.py
scripts/_*.js

# Scratch outputs — generated SQL, audit reports, etc. Not source.
scratch/

# Review inbox — drop docs/test files here for Claude Code to read. Not source.
.review/

# Generated Bunny CDN file listing — regenerable via scripts/bunny-list-medvoice.js
scripts/bunny-medvoice-listing.json

# Local Supabase test stack — mirrors prod schema/content; local dev infra, never commit
supabase/

# Generated /marketing skill output — planning docs, not source (like .review/)
.marketing/

# Landing mockup source images — large binaries, not referenced by app code
# (curated/optimized assets live in app/public/ instead)
landing-shots/

# Logs — dev-server / build output, regenerable
*.log

# Orphan dev-only route (unlinked visual-concepts playground) — kept local, not shipped
app/src/app/dev/

# One-off data-import scripts (already run against prod; read machine-local sources)
scripts/add-pediatria-simulado-3.js
scripts/import-revalida-questoes.js
